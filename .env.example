# 必填：用于会话/CSRF 签名（至少 32+ 字符随机串）
AI_CHAT_SITE_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# 必填：Gemini API Key
GEMINI_API_KEY=CHANGE_ME

# 必填：允许的 Host（防 Host header 攻击）。多个用逗号分隔
# 例如：ai.example.com 或 ai.example.com,ai2.example.com
AI_CHAT_SITE_ALLOWED_HOSTS=ai.example.com

# 可选：Gemini 模型名
GEMINI_MODEL=gemini-2.5-flash

# 可选：允许前端选择的模型列表（逗号分隔）
GEMINI_ALLOWED_MODELS=gemini-2.5-flash,gemini-2.0-flash

# 可选：是否信任反代头（Cloudflare / Nginx / Caddy 等）
TRUST_PROXY_HEADERS=1

# 可选：是否强制 HTTPS（在 CF/Tunnel 下通常应为 1）
FORCE_HTTPS=1

# 可选：数据文件路径（SQLite）
DATABASE_PATH=/data/ai_chat_site.sqlite3

# 可选：Cloudflare Tunnel Token（Zero Trust 控制台创建 Tunnel 时给的 token）
# 配好后用 `docker-compose -f docker-compose.yml -f docker-compose.tunnel.yml up -d --build`
CLOUDFLARED_TOKEN=

# 可选：Cloudflare Turnstile（建议开启，防爆破/机器人注册）
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# 可选：记忆（跨对话检索）
MEMORY_ENABLED_DEFAULT=1
MEMORY_EMBED_MODEL=text-embedding-004
MEMORY_TOP_K=5
MEMORY_MAX_ITEMS=2000

# 可选：登录爆破防护（identifier+IP 维度）
LOCKOUT_MAX_FAILS=8
LOCKOUT_WINDOW_SECONDS=900
LOCKOUT_SECONDS=1800
